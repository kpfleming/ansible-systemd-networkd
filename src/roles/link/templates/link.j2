{% import 'macros.j2' as macros %}

{% if "match" in link -%}
  {% set m=link.match %}
[Match]
  {% if "device" in m -%}
{{ macros.generate_mapped_arguments(match_device_arguments, m.device) }}
  {% endif %}
  {% if "system" in m -%}
{{ macros.generate_mapped_arguments(match_system_arguments, m.system) }}
  {% endif %}
{% endif %}

{% if "link" in link -%}
[Link]
{{ macros.generate_mapped_arguments(link_arguments, link.link) }}
{% endif %}
